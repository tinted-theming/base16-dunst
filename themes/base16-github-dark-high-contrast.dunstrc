[global]
frame_color = "#f0f3f6"
separator_color = "#f0f3f6"

[base16_low]
    msg_urgency = "low"
    background = "#272b33"
    foreground = "#9ea7b3"

[base16_normal]
    msg_urgency = "normal"
    background = "#7a828e"
    foreground = "#f0f3f6"

[base16_critical]
    msg_urgency = "critical"
    background = "#ffb757"
    foreground = "#ffffff"

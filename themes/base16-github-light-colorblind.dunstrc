[global]
frame_color = "#424a53"
separator_color = "#424a53"

[base16_low]
    msg_urgency = "low"
    background = "#f6f8fa"
    foreground = "#8c959f"

[base16_normal]
    msg_urgency = "normal"
    background = "#afb8c1"
    foreground = "#424a53"

[base16_critical]
    msg_urgency = "critical"
    background = "#8a4600"
    foreground = "#32383f"

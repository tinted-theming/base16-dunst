[global]
frame_color = "#adbac7"
separator_color = "#adbac7"

[base16_low]
    msg_urgency = "low"
    background = "#2d333b"
    foreground = "#636e7b"

[base16_normal]
    msg_urgency = "normal"
    background = "#545d68"
    foreground = "#adbac7"

[base16_critical]
    msg_urgency = "critical"
    background = "#f69d50"
    foreground = "#cdd9e5"

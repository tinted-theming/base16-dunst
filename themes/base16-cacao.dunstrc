[global]
frame_color = "#e8d6c4"
separator_color = "#e8d6c4"

[base16_low]
    msg_urgency = "low"
    background = "#241913"
    foreground = "#766052"

[base16_normal]
    msg_urgency = "normal"
    background = "#3a281e"
    foreground = "#e8d6c4"

[base16_critical]
    msg_urgency = "critical"
    background = "#e0705c"
    foreground = "#eedecd"

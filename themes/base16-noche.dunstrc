[global]
frame_color = "#cbd4ec"
separator_color = "#cbd4ec"

[base16_low]
    msg_urgency = "low"
    background = "#181c2c"
    foreground = "#5a6178"

[base16_normal]
    msg_urgency = "normal"
    background = "#232a40"
    foreground = "#cbd4ec"

[base16_critical]
    msg_urgency = "critical"
    background = "#e2727e"
    foreground = "#d9e0f3"

[global]
frame_color = "#cfe5d2"
separator_color = "#cfe5d2"

[base16_low]
    msg_urgency = "low"
    background = "#16211a"
    foreground = "#5c6e5e"

[base16_normal]
    msg_urgency = "normal"
    background = "#1e3023"
    foreground = "#cfe5d2"

[base16_critical]
    msg_urgency = "critical"
    background = "#e2706a"
    foreground = "#daebda"

[global]
frame_color = "#d2c3a4"
separator_color = "#d2c3a4"

[base16_low]
    msg_urgency = "low"
    background = "#3a3124"
    foreground = "#5f4e41"

[base16_normal]
    msg_urgency = "normal"
    background = "#4d3f32"
    foreground = "#d2c3a4"

[base16_critical]
    msg_urgency = "critical"
    background = "#db930d"
    foreground = "#ebe0bb"

[global]
frame_color = "#5b5b49"
separator_color = "#5b5b49"

[base16_low]
    msg_urgency = "low"
    background = "#dedeb2"
    foreground = "#9c9c7d"

[base16_normal]
    msg_urgency = "normal"
    background = "#bdbd97"
    foreground = "#5b5b49"

[base16_critical]
    msg_urgency = "critical"
    background = "#ffbfa5"
    foreground = "#3a3a2e"

[global]
frame_color = "#64513e"
separator_color = "#64513e"

[base16_low]
    msg_urgency = "low"
    background = "#ddcebc"
    foreground = "#b5a492"

[base16_normal]
    msg_urgency = "normal"
    background = "#c9b9a7"
    foreground = "#64513e"

[base16_critical]
    msg_urgency = "critical"
    background = "#d09700"
    foreground = "#786653"

[global]
frame_color = "#343b43"
separator_color = "#343b43"

[base16_low]
    msg_urgency = "low"
    background = "#e7ecf0"
    foreground = "#88929d"

[base16_normal]
    msg_urgency = "normal"
    background = "#acb6c0"
    foreground = "#343b43"

[base16_critical]
    msg_urgency = "critical"
    background = "#702c00"
    foreground = "#20252c"

[global]
frame_color = "#433b32"
separator_color = "#433b32"

[base16_low]
    msg_urgency = "low"
    background = "#beb6ae"
    foreground = "#8a8075"

[base16_normal]
    msg_urgency = "normal"
    background = "#a39a90"
    foreground = "#433b32"

[base16_critical]
    msg_urgency = "critical"
    background = "#826d57"
    foreground = "#2c2620"

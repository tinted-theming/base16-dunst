[global]
frame_color = "#1f1c16"
separator_color = "#1f1c16"

[base16_low]
    msg_urgency = "low"
    background = "#e8e7e3"
    foreground = "#91887d"

[base16_normal]
    msg_urgency = "normal"
    background = "#d5d2cb"
    foreground = "#1f1c16"

[base16_critical]
    msg_urgency = "critical"
    background = "#9e3e3e"
    foreground = "#6e6459"

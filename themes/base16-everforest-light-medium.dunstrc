[global]
frame_color = "#5c6a72"
separator_color = "#5c6a72"

[base16_low]
    msg_urgency = "low"
    background = "#f4f0d9"
    foreground = "#939f91"

[base16_normal]
    msg_urgency = "normal"
    background = "#e6e2cc"
    foreground = "#5c6a72"

[base16_critical]
    msg_urgency = "critical"
    background = "#f85552"
    foreground = "#475258"
